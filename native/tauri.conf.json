{
  "productName": "arr-mcp",
  "version": "1.0.0",
  "identifier": "ai.fleet.arr-mcp",
  "build": {
    "frontendDist": "../webapp/dist",
    "devUrl": "http://localhost:10939",
    "beforeDevCommand": "npm --prefix ../webapp run dev"
  },
  "app": {
    "windows": [
      {
        "title": "arr-mcp",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "externalBin": ["binaries/arr-mcp-backend"]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "process": {
      "all": true
    }
  }
}
